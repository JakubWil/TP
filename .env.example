# Sanity CMS – copy to .env.local (Next.js) i do .env (Studio)
# Project ID: https://www.sanity.io/manage

# Next.js (npm run dev)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity Studio (npx sanity dev) – Vite wymaga prefiksu VITE_
VITE_SANITY_PROJECT_ID=your_project_id
VITE_SANITY_DATASET=production

# Preview / Visual Editing (opcjonalne)
# W development bez secret też działa. W produkcji ustaw SANITY_PREVIEW_SECRET.
SANITY_PREVIEW_SECRET=your_random_secret
# URL strony dla Presentation Tool (np. https://twoja-domena.com)
VITE_SANITY_PREVIEW_URL=http://localhost:3000
# URL Sanity Studio – dla ramek Visual Editing (np. http://localhost:3333 gdy Studio pod npx sanity dev)
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333
